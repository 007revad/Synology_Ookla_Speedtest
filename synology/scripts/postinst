#!/bin/bash

PKG_NAME=$(basename "$SYNOPKG_PKGDEST")
TARGET_DIR="/var/packages/$PKG_NAME/target"
UI_DIR="$TARGET_DIR/ui"
VAR_DIR="/var/packages/$PKG_NAME/var"

# Log function
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$VAR_DIR/install.log" 2>/dev/null || echo "$1"
}

log_message "Post-installation starting for package: $PKG_NAME"

# Create VAR directory
if mkdir -p "$VAR_DIR"; then
    log_message "VAR_DIR created or already exists: $VAR_DIR"
else
    log_message "Error: Failed to create VAR_DIR: $VAR_DIR"
    exit 1
fi

# Create symbolic link for UI
if ln -sf "/var/packages/$PKG_NAME/target/ui" "/usr/syno/synoman/webman/3rdparty/$PKG_NAME" 2>/dev/null; then
    log_message "Created web interface symlink"
else
    log_message "Warning: Failed to create web interface symlink"
    ERRORS="1"
fi

# Create symbolic link for armv71
if ln -sf armhf "/var/packages/$PKG_NAME/target/bin/armv71" 2>/dev/null; then
    log_message "Created armv71 symlink to armhf"
else
    log_message "Warning: Failed to create armv71 symlink to armhf"
    ERRORS="1"
fi
# Create symbolic link for armv7  # Probably not needed for Synology NAS
if ln -sf armhf "/var/packages/$PKG_NAME/target/bin/armv7" 2>/dev/null; then
    log_message "Created armv7 symlink to armhf"
else
    log_message "Warning: Failed to create armv7 symlink to armhf"
    ERRORS="1"
fi

# Create symbolic link for armv5tel
if ln -sf armel "/var/packages/$PKG_NAME/target/bin/armv5tel" 2>/dev/null; then
    log_message "Created armv5tel symlink to armel"
else
    log_message "Warning: Failed to create armv5tel symlink to armel"
    ERRORS="1"
fi
# Create symbolic link for armv5  # Probably not needed for Synology NAS
if ln -sf armel "/var/packages/$PKG_NAME/target/bin/armv5" 2>/dev/null; then
    log_message "Created armv5 symlink to armel"
else
    log_message "Warning: Failed to create armv5 symlink to armel"
    ERRORS="1"
fi

# Create symbolic link for i686
if ln -sf i386 "/var/packages/$PKG_NAME/target/bin/i686" 2>/dev/null; then
    log_message "Created i686 symlink to i386"
else
    log_message "Warning: Failed to create i686 symlink to i386"
    ERRORS="1"
fi

# Create result directory in webman (for static file serving)
RESULT_DIR="/usr/syno/synoman/webman/3rdparty/$PKG_NAME/result"
if mkdir -p "$RESULT_DIR"; then
    log_message "Created result directory: $RESULT_DIR"
    chmod 755 "$RESULT_DIR"
else
    log_message "Warning: Failed to create result directory: $RESULT_DIR"
    ERRORS="1"
fi

# Set execute permissions for scripts
BIN_DIR="$TARGET_DIR/bin"
chmod +x "$BIN_DIR/speedtest.sh" 2>/dev/null
#chmod +x "$BIN_DIR/servers.sh" 2>/dev/null
#chmod +x "$BIN_DIR/generate_speedtest_result.sh" 2>/dev/null

# Set execute permissions for speedtest binaries
BIN_DIR="$TARGET_DIR/bin"
chmod +x "$BIN_DIR/aarch64/speedtest" 2>/dev/null
chmod +x "$BIN_DIR/armel/speedtest" 2>/dev/null
chmod +x "$BIN_DIR/armhf/speedtest" 2>/dev/null
chmod +x "$BIN_DIR/i386/speedtest" 2>/dev/null
chmod +x "$BIN_DIR/x86_64/speedtest" 2>/dev/null

# Set execute permissions for API CGI
chmod +x "$UI_DIR/api.cgi" 2>/dev/null
log_message "Set execute permissions for api.cgi"

# Syno Ookla Speedtest sudoers configuration
# Configure sudoers for web UI scripts
#SUDOERS_FILE="/etc/sudoers.d/Synospeedtest"
#cat << 'EOF' | sudo tee "$SUDOERS_FILE" >/dev/null
#Synospeedtest ALL=(ALL) NOPASSWD: ALL
#EOF
#
#sudo chmod 0440 "$SUDOERS_FILE"
#log_message "Sudoers file created and permissions set: $SUDOERS_FILE"

if [ -z "$ERRORS" ]; then
    log_message "Post-installation completed successfully"
else
    log_message "Post-installation completed with warnings"
fi
echo >> "$VAR_DIR/install.log"
exit 0
